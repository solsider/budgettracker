# Секретный ключ Flask для сессий и CSRF-защиты.
SECRET_KEY=change-me

# Режим приложения: development или production.
FLASK_ENV=development

# База данных по умолчанию для локальной разработки.
DATABASE_URL=sqlite:///budgettracker.db

# Порт, на котором запускается Flask-приложение.
PORT=8000

# Хост для встроенного сервера Flask.
FLASK_RUN_HOST=0.0.0.0
